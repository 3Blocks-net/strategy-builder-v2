# Deployer private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# BSC RPC URLs.
# NOTE: forking needs an ARCHIVE-capable RPC (BlastAPI, Alchemy, QuickNode).
# Public dataseed nodes fail with "missing trie node".
BSC_MAINNET_RPC_URL=https://bsc-mainnet.public.blastapi.io
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# BscScan API key for contract verification
# Get one at https://bscscan.com/myapikey
BSCSCAN_API_KEY=your_bscscan_api_key_here

# ── Keeper (scripts/execute-automations.ts) ──────────────────────────────────
# Factory whose vaults the keeper iterates (defaults to deployments/fork-latest.json).
FACTORY_ADDRESS=
# Run the keeper as a specific external (non-owner) account; defaults to signer #0.
EXECUTOR_PRIVATE_KEY=
# Set to 1 to skip syncing the fork clock to wall-clock before checking triggers.
SKIP_TIME_SYNC=

# Keeper failure reporting (PEC-219 #05). The keeper POSTs reverts to the backend
# ingest endpoint, authenticated by this shared secret (must match the backend's
# KEEPER_INGEST_SECRET). Leave KEEPER_INGEST_SECRET empty to disable reporting.
KEEPER_INGEST_URL=http://localhost:3001
KEEPER_INGEST_SECRET=
