{
  "name": "mcp",
  "version": "1.0.0",
  "private": true,
  "description": "Pecunity MCP server — steuert DeFi-Vaults der eigenen Wallet per KI-Assistent (stdio)",
  "type": "module",
  "bin": {
    "pecunity-mcp": "./dist/index.js",
    "pecunity-mcp-init": "./dist/cli/init.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "start": "node dist/index.js",
    "init": "node dist/cli/init.js",
    "inspect": "pnpm build && pnpm dlx @modelcontextprotocol/inspector node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ethers": "^6.16.0",
    "keytar": "^7.9.0",
    "siwe": "^3.0.0",
    "viem": "^2.31.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
