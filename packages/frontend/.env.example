# Backend API base URL. Also the origin for the real-time execution WebSocket
# (PEC-219) — the /executions Socket.IO namespace connects to this host.
VITE_API_URL=http://localhost:3001

# Vault factory address (from the deploy output / deployments/fork-latest.json).
VITE_FACTORY_ADDRESS=0x...

# Optional — PancakeSwap V3 factory for the Swap node's pool-existence check.
# Defaults to the live BSC factory; only override for a non-BSC fork.
VITE_PCS_FACTORY_ADDRESS=
