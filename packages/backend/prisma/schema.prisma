generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  createdAt     DateTime @default(now())
  lastLoginAt   DateTime @default(now())
  vaults        Vault[]
}

model Nonce {
  id        String   @id @default(uuid())
  nonce     String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
}

model RefreshToken {
  id            String   @id @default(uuid())
  tokenHash     String   @unique
  walletAddress String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

model Vault {
  id             String       @id @default(uuid())
  address        String       @unique
  chainId        Int
  ownerAddress   String
  depositToken   String
  label          String
  createdAtBlock Int
  txHash         String
  contextSlots   Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  owner          User         @relation(fields: [ownerAddress], references: [walletAddress])
  events         VaultEvent[]
  automations    Automation[]

  @@unique([ownerAddress, label])
}

model VaultEvent {
  id             String   @id @default(uuid())
  vaultId        String
  eventType      String
  token          String
  amount         String
  feeAmount      String
  feeBps         Int
  txHash         String
  blockNumber    Int
  blockTimestamp  DateTime
  createdAt      DateTime @default(now())
  vault          Vault    @relation(fields: [vaultId], references: [id])
}

enum StepCategory {
  CONDITION
  ACTION
}

model Automation {
  id          String   @id @default(uuid())
  vaultId     String
  onChainId   Int?
  label       String?
  description String?
  ownerOnly   Boolean  @default(false)
  editorState Json?
  stepCount   Int      @default(0)
  isDraft     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vault       Vault    @relation(fields: [vaultId], references: [id], onDelete: Cascade)

  @@unique([vaultId, onChainId])
}

/// Curated per-protocol token allowlist (Aave reserves, PancakeSwap pairs).
/// Only standard ERC-20s — no fee-on-transfer / rebasing tokens, which would
/// break context-slot amount accounting. `decimals` feeds the frontend
/// tokenDecimals map so token-amount → base-units conversion is correct.
model ProtocolToken {
  id        String   @id @default(uuid())
  protocol  String
  address   String
  symbol    String
  decimals  Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([protocol, address])
}

model StepType {
  id                     String       @id @default(uuid())
  name                   String
  description            String
  category               StepCategory
  contractAddress        String
  selector               String
  afterExecutionSelector String?
  abiFragment            Json
  paramSchema            Json
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@unique([contractAddress, selector])
}
