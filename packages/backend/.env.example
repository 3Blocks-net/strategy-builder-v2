# Environment                                                                                               
NODE_ENV=development 

# PostgreSQL connection string
DATABASE_URL=postgresql://pecunity:pecunity@localhost:5432/pecunity

# JWT configuration
JWT_SECRET=change-me-to-a-random-256-bit-hex-value
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY_DAYS=7

# Frontend URL (CORS origin + SIWE domain validation)
FRONTEND_URL=http://localhost:5173

# SIWE nonce time-to-live in seconds
NONCE_EXPIRY_SECONDS=300

# Backend server port
PORT=3001

# On-chain (BSC) — fill in from the deploy output (deployments/fork-latest.json).
# RPC_URL + FEE_REGISTRY_ADDRESS are also read by the execution indexer.
RPC_URL=http://localhost:8545
FACTORY_ADDRESS=
FEE_REGISTRY_ADDRESS=

# Execution indexer (PEC-219). All optional — sensible defaults applied in code.
# On the local BSC fork set INDEXER_CONFIRMATIONS=0: the fork has no reorgs and an
# idle fork never mines the confirmation blocks, so deposits/executions would
# otherwise stay "unconfirmed" forever. Raise it on mainnet for reorg safety.
# INDEXER_ENABLED=true            # set "false" to keep the loop dormant (e.g. tests)
# INDEXER_CONFIRMATIONS=5         # only index blocks <= head - N (reorg safety vs 30s SLA)
# INDEXER_MAX_RANGE=2000          # max getLogs window; adaptive-halved on RPC range errors
# INDEXER_POLL_INTERVAL_MS=6000   # self-rescheduling poll cadence
# INDEXER_START_BLOCK=            # first block to backfill from (factory deploy block);
#                                 # defaults to min(Vault.createdAtBlock), else chain head

# Keeper failure ingest (PEC-219 #05). Shared secret guarding
# POST /internal/executions/failures. The keeper must send it as the
# `x-keeper-secret` header. Unset = the endpoint rejects all calls (fail closed).
# KEEPER_INGEST_SECRET=change-me-to-a-shared-secret
